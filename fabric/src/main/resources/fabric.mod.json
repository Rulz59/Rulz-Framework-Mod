{
  "schemaVersion": 1,
  "name": "${mod_name}",
  "id": "${mod_id}",
  "version": "${version}",
  "description": "${mod_description}",
  "authors": ["${mod_authors}"],
  "contact": {
    "homepage": "${mod_issues}",
    "sources": "${mod_homepage}"
  },
  "license": "${mod_license}",
  "icon": "${mod_icon}",
  "environment": "*",
  "entrypoints": {
    "main": [
      "net.rulz59.fabric.ExampleModFabric"
    ],
    "client": [
      "net.rulz59.fabric.client.ExampleModFabricClient"
    ]
  },
  "mixins": [
    "rulzframework.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.19.3",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "architectury": ">=13.0.8",
    "fabric-api": "*"
  },
  "suggests": {
    "another-mod": "*"
  }
}
